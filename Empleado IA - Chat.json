      "parameters": {
        "jsCode": "const body = $json.body || {};\nconst headers = $json.headers || {};\n\nconst fullPath =\n  headers['x-forwarded-path'] ||\n  headers['x-original-url'] ||\n  headers['referer'] ||\n  '';\n\nlet businessSlug = body.business_slug || 'default';\n\nif (fullPath.includes('/webhook/negocio/')) {\n  businessSlug = fullPath.split('/webhook/negocio/')[1]?.split('?')[0] || businessSlug;\n}\n\n// Fallback por si n8n no manda x-forwarded-path en local\nif (businessSlug === 'default' && $json.params) {\n  businessSlug =\n    $json.params.businessSlug ||\n    $json.params[0] ||\n    $json.params.path ||\n    'default';\n}\n\nreturn [\n  {\n    json: {\n      business_slug: businessSlug,\n      client_id: body.client_id,\n      client_name: body.client_name,\n      business_id: body.business_id,\n      system_prompt: body.system_prompt || '',\n      message: body.message || '',\n      image_url: body.image_url || null,\n      history: Array.isArray(body.history) ? body.history : []\n    }\n  }\n];"
      },
