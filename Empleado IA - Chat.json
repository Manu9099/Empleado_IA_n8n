    {
      "parameters": {
        "jsCode": "const response = $json;\nlet reply = response.output || response.text || '';\n\n// Fix: Groq a veces expone etiquetas de function-calling en el texto plano\nreply = reply\n  .replace(/<function[^>]*>[\\s\\S]*?<\\/function>/gi, '')\n  .replace(/<\\|[^|]*\\|>/g, '')\n  .replace(/```json[\\s\\S]*?```/g, '')\n  .trim();\n\nif (!reply) {\n  reply = 'No pude generar una respuesta, intenta de nuevo.';\n}\n\nreturn [{\n  json: {\n    reply: reply,\n    image_url: null,\n    appointment: null\n  }\n}];"
      },
